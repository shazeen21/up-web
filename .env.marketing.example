# ─── ALREADY CONFIGURED ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://zdvnkcdedyqjkzmqvuok.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_UPHAAR_WHATSAPP=+919821141072
NEXT_PUBLIC_KYDDOZ_WHATSAPP=+918767174252

# ─── GOOGLE ANALYTICS 4 ─────────────────────────────────────
# Get from: https://analytics.google.com
# Admin → Data Streams → Web stream → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-LZDHJRQLWJ

# ─── META (FACEBOOK) PIXEL ───────────────────────────────────
# Get from: https://business.facebook.com/events-manager
# Events Manager → Connect Data Source → Web → Get Pixel ID
# Format: 15-16 digit number
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# ─── GOOGLE ADS ──────────────────────────────────────────────
# Get from: https://ads.google.com
# Tools → Conversions → Create conversion action → Website
# Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX/XXXXXXXXXXXX

# ─── ONESIGNAL PUSH NOTIFICATIONS ───────────────────────────
# Get from: https://onesignal.com
# Settings → Keys & IDs → App ID
NEXT_PUBLIC_ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OneSignal REST API key (for sending from server)
# Settings → Keys & IDs → REST API Key
ONESIGNAL_REST_API_KEY=your_rest_api_key_here

# Safari Web ID (optional, for Safari push support)
NEXT_PUBLIC_ONESIGNAL_SAFARI_WEB_ID=web.onesignal.auto.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── EMAIL SERVICE (RESEND) ──────────────────────────────────
# Get from: https://resend.com (free tier: 100 emails/day)
# API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified sender email address (must match your Resend domain)
EMAIL_FROM=Uphaar & Kyddoz <hello@uphaarandkyddoz.com>

# ─── OPTIONAL: SMTP FALLBACK ────────────────────────────────
# Alternative to Resend — use any SMTP provider (Gmail, Zoho, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password_here
# SMTP_FROM=Uphaar & Kyddoz <your@gmail.com>
